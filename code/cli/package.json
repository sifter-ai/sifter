{
  "name": "@sifter-ai/cli",
  "version": "0.1.0",
  "description": "Sifter CLI — document extraction from the command line",
  "type": "module",
  "bin": {
    "sifter": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "sifter",
    "cli",
    "document-extraction",
    "llm"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@sifter-ai/sdk": "file:../sdk-ts",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
