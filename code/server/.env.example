# ── LLM Provider ─────────────────────────────────────────────────────────────
# Required. Any LiteLLM-compatible model string.
SIFTER_LLM_API_KEY=sk-your-openai-key-here
SIFTER_LLM_MODEL=openai/gpt-4o
SIFTER_PIPELINE_MODEL=openai/gpt-4o-mini

# ── MongoDB ───────────────────────────────────────────────────────────────────
SIFTER_MONGODB_URI=mongodb://localhost:27017
SIFTER_MONGODB_DATABASE=sifter

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a random 64-char string in production!
SIFTER_JWT_SECRET=dev-secret-change-in-production
SIFTER_JWT_EXPIRE_MINUTES=1440

# ── Storage ───────────────────────────────────────────────────────────────────
SIFTER_STORAGE_PATH=./uploads
SIFTER_MAX_FILE_SIZE_MB=50

# ── Workers ───────────────────────────────────────────────────────────────────
SIFTER_MAX_WORKERS=4

# ── Server ────────────────────────────────────────────────────────────────────
SIFTER_HOST=0.0.0.0
SIFTER_PORT=8000
SIFTER_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
