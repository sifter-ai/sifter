# ── Default LLM ───────────────────────────────────────────────────────────────
# Fallback for all agents when no task-specific value is set.
# Any LiteLLM model string: openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022,
# vertex_ai/gemini-2.5-flash, gemini/gemini-2.5-flash, ollama/llama3, etc.
SIFTER_DEFAULT_MODEL=openai/gpt-4o
SIFTER_DEFAULT_API_KEY=sk-your-key-here
SIFTER_DEFAULT_BASE_URL=           # e.g. https://api.fireworks.ai/inference/v1

# ── Per-task overrides ────────────────────────────────────────────────────────
# Leave model/api_key/base_url blank to fall back to the SIFTER_DEFAULT_* values.

# Extraction agent — turns documents into structured records.
# Use a vision-capable model for scanned PDFs and images.
SIFTER_EXTRACTOR_MODEL=
SIFTER_EXTRACTOR_API_KEY=
SIFTER_EXTRACTOR_BASE_URL=

# Aggregation agent — translates natural language into MongoDB pipelines.
SIFTER_PIPELINE_MODEL=
SIFTER_PIPELINE_API_KEY=
SIFTER_PIPELINE_BASE_URL=

# Chat agent — conversational Q&A over your extracted records.
SIFTER_CHAT_MODEL=
SIFTER_CHAT_API_KEY=
SIFTER_CHAT_BASE_URL=

# Dashboard agent — generates dashboard widgets from a natural language spec.
SIFTER_DASHBOARD_MODEL=
SIFTER_DASHBOARD_API_KEY=
SIFTER_DASHBOARD_BASE_URL=

# ── Native-credential providers (no API key needed) ───────────────────────────
# Vertex AI: set GOOGLE_APPLICATION_CREDENTIALS or use Workload Identity.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEXAI_PROJECT=my-gcp-project
# VERTEXAI_LOCATION=us-central1

# Gemini (AI Studio): set GEMINI_API_KEY (or SIFTER_EXTRACTOR_API_KEY).
# GEMINI_API_KEY=AIza...

# ── MongoDB ───────────────────────────────────────────────────────────────────
SIFTER_MONGODB_URI=mongodb://localhost:27017
SIFTER_MONGODB_DATABASE=sifter

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change to a random 64-char string in production.
SIFTER_API_KEY=sk-dev
SIFTER_REQUIRE_API_KEY=false
SIFTER_JWT_SECRET=dev-secret-change-in-production
SIFTER_JWT_EXPIRE_MINUTES=1440

# ── Storage ───────────────────────────────────────────────────────────────────
# Backend: "filesystem" (default), "s3", or "gcs"
SIFTER_STORAGE_BACKEND=filesystem
SIFTER_STORAGE_PATH=./uploads
SIFTER_MAX_FILE_SIZE_MB=50
SIFTER_MAX_PDF_PAGES=10

# S3 (used when SIFTER_STORAGE_BACKEND=s3)
# SIFTER_S3_BUCKET=my-bucket
# SIFTER_S3_REGION=us-east-1
# SIFTER_S3_ACCESS_KEY_ID=
# SIFTER_S3_SECRET_ACCESS_KEY=
# SIFTER_S3_ENDPOINT_URL=        # leave empty for AWS; set for MinIO/R2

# GCS (used when SIFTER_STORAGE_BACKEND=gcs)
# SIFTER_GCS_BUCKET=my-bucket
# SIFTER_GCS_PROJECT=my-project
# SIFTER_GCS_CREDENTIALS_FILE=   # leave empty to use Application Default Credentials

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to true to log full LLM request/response exchanges
# SIFTER_DEBUG_LLM=true

# ── Workers ───────────────────────────────────────────────────────────────────
SIFTER_MAX_WORKERS=4

# ── Server ────────────────────────────────────────────────────────────────────
SIFTER_HOST=0.0.0.0
SIFTER_PORT=8000
SIFTER_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# SIFTER_GOOGLE_CLIENT_ID=       # enables Google sign-in when set
