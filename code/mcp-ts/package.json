{
  "name": "@sifter-ai/mcp",
  "version": "0.1.0",
  "description": "MCP server for Sifter — document extraction via Model Context Protocol",
  "type": "module",
  "bin": {
    "sifter-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": ["sifter", "mcp", "document-extraction", "llm"],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sifter-ai/sdk": "file:../sdk-ts",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
